# .env.example

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# PostgreSQL (pgvector)
DATABASE_URL=postgresql://user:password@localhost:5432/mediquery

# AWS
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=mediquery-docs

# App Settings
APP_ENV=development
API_KEY=your_internal_api_key_for_securing_endpoints